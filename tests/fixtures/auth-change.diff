diff --git a/src/auth/middleware/validateSession.ts b/src/auth/middleware/validateSession.ts
index 1a2b3c4..5d6e7f8 100644
--- a/src/auth/middleware/validateSession.ts
+++ b/src/auth/middleware/validateSession.ts
@@ -1,15 +1,22 @@
 import { Request, Response, NextFunction } from 'express';
 import { SessionStore } from '../stores/SessionStore';
+import { AuditLogger } from '../../shared/logging/audit';
 
 export async function validateSession(req: Request, res: Response, next: NextFunction) {
   const sessionId = req.cookies?.session_id;
 
   if (!sessionId) {
-    return res.status(401).json({ error: 'No session' });
+    AuditLogger.log('auth_failure', { reason: 'missing_session', ip: req.ip });
+    return res.status(401).json({ error: 'Authentication required' });
   }
 
-  const session = await SessionStore.get(sessionId);
-  if (!session) {
-    return res.status(401).json({ error: 'Invalid session' });
+  const session = await SessionStore.get(sessionId, { refresh: true });
+  if (!session || session.expiresAt < Date.now()) {
+    AuditLogger.log('auth_failure', { reason: 'expired_session', sessionId });
+    return res.status(401).json({ error: 'Session expired' });
+  }
+
+  if (session.role !== req.body?.requiredRole && req.body?.requiredRole) {
+    AuditLogger.log('auth_failure', { reason: 'insufficient_role', sessionId, required: req.body.requiredRole });
+    return res.status(403).json({ error: 'Insufficient permissions' });
   }
 
   req.user = session.user;
