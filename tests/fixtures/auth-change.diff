@@ -8,8 +8,12 @@
 export function generateToken(userId: string, role: string): string {
-  return jwt.sign({ userId, role }, SECRET, { expiresIn: '24h' });
+  const payload = { userId, role, mfa: false };
+  return jwt.sign(payload, SECRET, {
+    expiresIn: '24h',
+    algorithm: 'RS256'
+  });
 }
 
-export function verifyToken(token: string): TokenPayload {
-  return jwt.verify(token, SECRET) as TokenPayload;
+export function verifyToken(token: string, options?: VerifyOptions): TokenPayload {
+  return jwt.verify(token, SECRET, { algorithms: ['RS256'], ...options }) as TokenPayload;
 }
